# AcaBot 运行环境变量
# 复制为 .env 后填入实际值

# --- 端口 (compose.yaml 读取) ---
ACABOT_PORT=1220
ACABOT_WEBUI_PORT=8765
NAPCAT_WEBUI_PORT=6100

# --- LLM API Keys (按需填写, 取决于 config.yaml 里 agent.default_model 用哪家) ---
# litellm 自动读取这些环境变量, 不要在 config.yaml 里配置

OPENAI_API_KEY=sk-xxx
# OPENAI_API_BASE=https://api.openai.com/v1
