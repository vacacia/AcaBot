# AcaBot 环境变量
# 复制为 .env 后填入实际值

# --- 端口 (docker-compose 读取) ---
ACABOT_PORT=1220               # AcaBot WebSocket 服务端口
NAPCAT_WEBUI_PORT=6100         # NapCat 端口

# --- LLM API Keys (按需填写, 取决于 config.yaml 里 agent.default_model 用哪家) ---
# litellm 自动读取这些环境变量, 不要在 config.yaml 里配置

# OpenAI / OpenAI 兼容接口
OPENAI_API_KEY=sk-xxx
# OPENAI_API_BASE=https://api.openai.com/v1

# 其他 provider 参见 litellm 文档: https://docs.litellm.ai/docs/providers
